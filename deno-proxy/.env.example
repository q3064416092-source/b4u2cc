# b4u2cc 代理配置示例
# 复制此文件为 .env 并修改配置

# 上游 API 配置
UPSTREAM_BASE_URL=http://your-upstream-api/v1/chat/completions
UPSTREAM_API_KEY=your-api-key-here
UPSTREAM_MODEL=

# 服务配置
PORT=3456
HOST=0.0.0.0

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 请求限制
MAX_REQUESTS_PER_MINUTE=60
TIMEOUT_MS=30000

# Token 计算倍数
TOKEN_MULTIPLIER=1.0
